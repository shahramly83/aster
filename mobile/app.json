{
  "expo": {
    "name": "Aster",
    "slug": "aster-mobile",
    "scheme": "aster",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hireaster.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Unlock Aster with Face ID."
      }
    },
    "android": {
      "package": "com.hireaster.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B2AE0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#0B2AE0"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0B2AE0"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "supabaseUrl": "https://edaefharlofwhnmcbiwk.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVkYWVmaGFybG9md2hubWNiaXdrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMzMDk5NDcsImV4cCI6MjA5ODg4NTk0N30.fZGe33f2KsIkvaRAjj8ZV4NAIrzWCkFPUxyE9hyYI1A"
    }
  }
}
