# Aster — environment variables.
# Copy this file to `.env.local` and fill in your Supabase project's values.
# `.env.local` is gitignored, so your keys never get committed.
#
# Find these in the Supabase dashboard: Project Settings -> API.

# Your project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The "anon" / public key. Safe to expose in the browser because access is
# controlled by Row Level Security (RLS) policies in the database.
VITE_SUPABASE_ANON_KEY=

# IMPORTANT: never put the `service_role` (secret) key in any VITE_* variable
# or anywhere in client code — it bypasses RLS. It belongs only in server-side
# / edge-function environments.
